{
  "name": "immersive-web-editor-repo",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.18.0",
  "scripts": {
    "dev:editor": "pnpm --filter @immersive-web-editor/example-editor-layout dev",
    "dev:example": "pnpm --filter @immersive-web-editor/example-vite-react-ai dev",
    "build": "pnpm -r --filter './packages/*' build",
    "typecheck": "tsc -b",
    "publish:packages": "pnpm -r --filter './packages/*' --access public publish --no-git-checks"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
