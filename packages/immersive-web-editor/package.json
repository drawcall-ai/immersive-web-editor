{
  "name": "immersive-web-editor",
  "version": "0.0.1",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/drawcall-ai/immersive-web-editor.git",
    "directory": "packages/immersive-web-editor"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "browser": "./src/client-public.ts",
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./editor-shell": {
      "import": "./src/client/editor-shell.tsx"
    },
    "./editor-components": {
      "types": "./src/editor-components.ts",
      "import": "./src/editor-components.ts"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.build.json",
    "build:server": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "node test/file-url-schema.test.mjs"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "browser": "./dist/client-public.js",
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./editor-shell": {
        "import": "./dist/client/editor-shell.js"
      },
      "./editor-components": {
        "types": "./dist/editor-components.d.ts",
        "import": "./dist/editor-components.js"
      }
    }
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "vite": "^7.0.0 || ^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.6.0",
    "vite": "^8.0.0"
  },
  "dependencies": {
    "@emotion/css": "^11.13.5",
    "@immersive-web-editor/adapter": "workspace:*",
    "@immersive-web-editor/ui": "workspace:*",
    "@pmndrs/handle": "^6.6.29",
    "@pmndrs/pointer-events": "^6.6.29",
    "@react-three/fiber": "^9.6.1",
    "@react-three/handle": "^6.6.29",
    "@react-three/xr": "^6.6.29",
    "cmdk": "^1.1.1",
    "esbuild": "^0.27.3",
    "lucide-react": "^0.468.0",
    "picocolors": "^1.1.1",
    "three": "^0.184.0"
  }
}
