{
  "name": "@immersive-web-editor/ai",
  "version": "0.0.1",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/drawcall-ai/immersive-web-editor.git",
    "directory": "packages/ai"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./register": {
      "import": "./dist/client/register.js"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.build.json",
    "build:server": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "vite": "^7.0.0 || ^8.0.0"
  },
  "dependencies": {
    "@emotion/css": "^11.13.5",
    "immersive-web-editor": "workspace:*",
    "@opencode-ai/sdk": "^1.14.20",
    "@tanstack/react-query": "^5.100.6",
    "@types/dompurify": "^3.0.5",
    "dompurify": "^3.4.1",
    "lucide-react": "^0.468.0",
    "marked": "^18.0.2",
    "opencode-ai": "^1.14.30"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.6.0",
    "vite": "^8.0.0"
  }
}
